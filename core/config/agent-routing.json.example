{
  "$schema": "./agent-routing.schema.json",
  "_schema_version": 1,
  "_comment": "Routage déterministe des agents/skills sur UserPromptSubmit. Première règle qui matche gagne. Voir core/docs/AGENT-ROUTING.md.",
  "rules": [
    {
      "id": "doc-generation",
      "match": { "regex": "documente|javadoc|jsdoc|readme|openapi|swagger|commente|doc technique|mise.?[aà].?jour.*doc" },
      "target": { "type": "agent", "name": "doc-writer" },
      "force": true,
      "reason": "Génération de documentation — déléguer systématiquement au sous-agent doc-writer (cf. CLAUDE.md global)."
    },
    {
      "id": "security-audit",
      "match": { "regex": "s[eé]curit|audit.{0,20}s[eé]cu|owasp|vuln[eé]rabilit|inject(ion)?|secret|jwt|xss|csrf|permiss" },
      "target": { "type": "skill", "name": "security-reviewer" },
      "force": true,
      "reason": "Audit sécurité — skill security-reviewer obligatoire avant tout déploiement sensible."
    },
    {
      "id": "database-expertise",
      "match": { "regex": "database|sql|nosql|schema|index|migration|query|postgres|mongo|redis|explain|requ[eê]te lente|slow query" },
      "target": { "type": "skill", "name": "database-expert" },
      "force": true,
      "reason": "Tâche base de données — skill database-expert obligatoire pour migrations/index/perf."
    },
    {
      "id": "frontend-expertise",
      "match": { "regex": "frontend|react|vue\\.js|vuejs|angular|next\\.js|nextjs|nuxt|ssr|csr|a11y|accessib|composant|component|web vital|render|hydration" },
      "target": { "type": "skill", "name": "frontend-expert" },
      "force": false,
      "reason": "Tâche frontend — skill frontend-expert recommandé pour SSR/CSR, perf, a11y."
    },
    {
      "id": "agentic-architecture",
      "match": { "regex": "agenti|multi.?agent|orchestrat|sous.?agent|a2a|d[eé]l[eé]gation.*agent|workflow.*agent|agent.*workflow|mcp.*script|hook.*llm|llm.*hook|context.*window.*agent|agent.*autonome" },
      "target": { "type": "skill", "name": "agentic-architect" },
      "force": true,
      "reason": "Architecture agentique — skill agentic-architect requis pour les décisions d'orchestration et de routing multi-agent."
    },
    {
      "id": "cognitive-design",
      "match": { "regex": "charge.{0,10}cognitiv|m[eé]moire.{0,10}travail|attention.{0,10}utilisateur|r[eé]tention|onboarding.*cognitif|biais.{0,10}cognitif|flow.?state|cogniti|cerveau|neuroscien|tdah|adhd" },
      "target": { "type": "skill", "name": "brain-expert" },
      "force": false,
      "reason": "Design cognitif — skill brain-expert recommandé pour les décisions UX/workflow fondées sur la cognition humaine."
    },
    {
      "id": "backend-architecture",
      "match": { "regex": "architect|api|restful|rest\\s*api|api\\s*rest|graphql|grpc|microserv|monolith|backend|design pattern|ddd|cqrs|hexagonal" },
      "target": { "type": "skill", "name": "backend-architect" },
      "force": false,
      "reason": "Décision d'architecture backend — skill backend-architect recommandé pour les trade-offs."
    },
    {
      "id": "devops",
      "match": { "regex": "ci.?cd|pipeline|gitlab.?ci|github.?action|dockerfile|docker.?build|docker.?image|kubernetes|k8s|helm|terraform|ansible|infra.*as.*code|\\biac\\b|blue.?green|canary|rollback|deploy|observabilit|prometheus|grafana|\\bsre\\b|gitops|container.?registry|devops" },
      "target": { "type": "skill", "name": "devops-expert" },
      "force": false,
      "reason": "Tâche DevOps — skill devops-expert recommandé pour CI/CD, Docker, K8s et bonnes pratiques infra."
    },
    {
      "id": "code-review",
      "match": { "regex": "review|relire|valide ce code|qualit|lisibilit|solid|mainten|refactor|propre|clean code" },
      "target": { "type": "skill", "name": "code-reviewer" },
      "force": false,
      "reason": "Review qualité — charger le skill code-reviewer pour appliquer la grille SOLID + lisibilité."
    }
  ]
}
