{
  "_cortexhub_hooks_version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "_cortexhub": "session-context-load",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.ai-core/scripts/session-context-load.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "_cortexhub": "suggest-skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.ai-core/scripts/suggest-skill.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "_cortexhub": "guard-no-claude-in-commit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.ai-core/scripts/guard-no-claude-in-commit.sh"
          }
        ]
      }
    ]
  }
}
